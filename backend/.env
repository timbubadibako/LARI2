# 🛠️ LARI2 BACKEND CONFIGURATION
# Pure local PostgreSQL setup

# Database URL format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:LARI2@localhost:5432/LARI2?sslmode=disable

# Local Development Port
PORT=8080

# Base URL for Tunneling (Edit this when using ngrok/cloudflare)
BASE_URL=http://localhost:8080
